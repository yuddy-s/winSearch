{
  "name": "winsearch",
  "private": true,
  "version": "0.1.0",
  "description": "Spotlight-style launcher for Windows built with Tauri + React.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420 --strictPort --configLoader native",
    "build": "tsc -b && vite build --configLoader native",
    "preview": "vite preview --host 127.0.0.1 --port 1421 --strictPort --configLoader native",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run --configLoader native --pool threads",
    "test:watch": "vitest --configLoader native --pool threads",
    "check": "npm run lint && npm run test && npm run build",
    "setup": "powershell -ExecutionPolicy Bypass -File ./scripts/bootstrap.ps1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yuddy-s/winSearch.git"
  },
  "bugs": {
    "url": "https://github.com/yuddy-s/winSearch/issues"
  },
  "homepage": "https://github.com/yuddy-s/winSearch#readme",
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.10.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
